# Postgres connection string.
#
# Self-hosted (VPS, Docker, etc.):
#   postgresql://USER:PASSWORD@localhost:5432/DBNAME
#
# Supabase: use the Transaction pooler URL (port 6543) with ?pgbouncer=true.
# See DEPLOY.md for the full walkthrough.
DATABASE_URL="postgresql://worldcup:PASSWORD@localhost:5432/worldcup"

# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# Admin is granted per-user via the User.isAdmin column. After the schema is
# pushed, mark your first user as admin in psql:
#   UPDATE "User" SET "isAdmin" = true WHERE "displayName" = 'your-handle';
# That user can then promote others from the /admin page.
