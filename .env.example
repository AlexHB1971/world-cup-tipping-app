# Postgres connection string.
#
# Self-hosted (VPS, Docker, etc.):
#   postgresql://USER:PASSWORD@localhost:5432/DBNAME
#
# Supabase: use the Transaction pooler URL (port 6543) with ?pgbouncer=true.
# See DEPLOY.md for the full walkthrough.
DATABASE_URL="postgresql://worldcup:PASSWORD@localhost:5432/worldcup"

# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"
ADMIN_SECRET="admin-change-me"
